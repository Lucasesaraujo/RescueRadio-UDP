# ──────────────────────────────────────────────────────────────────
# Central de Comunicação de Resgate — Configuração do Administrador
# ──────────────────────────────────────────────────────────────────
#
# Copie este arquivo para ".env" e preencha os valores antes de
# executar o admin.py pela primeira vez.
#
#   cp .env.example .env
#
# IMPORTANTE:
#   - Nunca commite o arquivo .env no repositório (já está no .gitignore)
#   - Em Linux/Mac, restrinja as permissões:  chmod 600 .env
#   - Use uma senha forte (mínimo 12 caracteres)
# ──────────────────────────────────────────────────────────────────

ADMIN_USER=admin
ADMIN_PASSWORD=troque_por_senha_forte
